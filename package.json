{
  "name": "paladin",
  "type": "module",
  "version": "0.1.0",
  "description": "Paladin - a software application to help individuals report fraud.",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --exec \"npm run build && npm start\"",
    "format": "prettier --list-different .",
    "format:fix": "prettier --list-different --write .",
    "prepare": "husky",
    "start": "npx serve . -l 3000",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
