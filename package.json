{
  "name": "paladin",
  "type": "module",
  "version": "0.1.0",
  "description": "Paladin - a software application to help individuals report fraud.",
  "scripts": {
    "build": "vite build",
    "dev": "npm run dev:server",
    "dev:client": "vite dev",
    "dev:server": "nodemon --watch index.js --exec \"node index.js\"",
    "format": "prettier --list-different .",
    "format:fix": "prettier --list-different --write .",
    "prepare": "husky",
    "preview": "vite preview",
    "start": "NODE_ENV=production node index.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
